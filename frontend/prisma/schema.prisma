// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  CONTENT_MANAGER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(SUPER_ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VisitorLog {
  id        String   @id @default(uuid())
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  country   String?
  pageUrl   String
  visitedAt DateTime @default(now())
}

enum BookCategory {
  NOVEL
  POETRY_COLLECTION
  STAGE_PLAY
  SHORT_STORIES
}

model Book {
  id               String       @id @default(uuid())
  title            String
  coverImage       String?
  shortDescription String?
  fullDescription  String?
  category         BookCategory @default(NOVEL)
  publishedYear    String?
  publisher        String?
  pages            Int?
  buyLink          String?
  isFeatured       Boolean      @default(false)
  displayOrder     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model GalleryCategory {
  id        String         @id @default(uuid())
  name      String         @unique // "Personal Photos", "Literary Events", etc.
  images    GalleryImage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model GalleryImage {
  id          String          @id @default(uuid())
  url         String
  title       String?
  description String?
  isFeatured  Boolean         @default(false)
  uploadDate  DateTime        @default(now())
  categoryId  String
  category    GalleryCategory @relation(fields: [categoryId], references: [id])
  displayOrder Int            @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model AboutContent {
  id                  String   @id @default(uuid())
  authorName          String   @default("Balakrishna")
  subtitle            String   @default("Author")
  profileImage        String?
  biography           String?
  biographyDesc       String?
  earlyLife           String?
  earlyLifeDesc       String?
  educationDesc       String?
  careerDesc          String?
  awardsDesc          String?
  legacyDesc          String?
  dob                 String?
  placeOfBirth        String?
  occupation          String?
  language            String?
  almaMater           String?
  awardsList          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Education {
  id          String   @id @default(uuid())
  institution String
  degree      String
  year        String
  createdAt   DateTime @default(now())
}

model CareerTimeline {
  id          String   @id @default(uuid())
  year        String
  title       String
  description String   @db.Text
  createdAt   DateTime @default(now())
}


